 "headline_finding": {
  "what": "Euler's imaginary-number multiplication error",
  "where": "Chapter XIII, Of Impossible or Imaginary Quantities (approx. leaf 80)",
  "detail": "Euler writes sqrt(-a)*sqrt(-b) = sqrt(ab), e.g. sqrt(-2)*sqrt(-3) = sqrt(6) and sqrt(-1)*sqrt(-4) = 2. Correct value: sqrt(-2)*sqrt(-3) = -sqrt(6). A famous error Euler himself made.",
  "instances": [
   "sqrt(-2) * sqrt(-3) = sqrt(6)",
   "sqrt(-1) * sqrt(-4) = sqrt(4)",
   "sqrt(-1) * sqrt(-4) = 2",
   "x - y*sqrt(-c) = m*(p - q*sqrt(-c))**2"
  ]
 },
